{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://api.placeholder.kingswalk.scada/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
