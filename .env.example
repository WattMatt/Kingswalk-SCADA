# Database
DATABASE_URL=postgresql+asyncpg://scada:scada_dev@localhost:5432/kingswalk_scada

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
JWT_ISSUER=kingswalk-scada

# Tokens
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# CSRF
CSRF_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# MFA — generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MFA_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_SECRET

# App
ENVIRONMENT=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173
VERSION=0.1.0
