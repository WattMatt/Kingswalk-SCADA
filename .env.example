# ─── Doppler (recommended) ───────────────────────────────────────────────────
# Production and CI secrets are managed by Doppler. For local dev, either:
#   a) Use Doppler CLI: doppler run -- uvicorn app.main:app --reload
#   b) Copy this file to .env and fill in the values manually (dev only)
#
# Doppler setup: https://docs.doppler.com/docs/install-cli
#   brew install dopplerhq/cli/doppler   # macOS
#   doppler login
#   doppler setup                        # reads doppler.yaml in this repo
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL + TimescaleDB connection string.
# asyncpg driver required (postgresql+asyncpg://).
DATABASE_URL=postgresql+asyncpg://scada:scada_dev@localhost:5432/kingswalk_scada

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis URL for login lockout + password-reset rate limiting.
REDIS_URL=redis://localhost:6379/0

# ─── Auth secrets ────────────────────────────────────────────────────────────
# JWT signing secret — min 64 hex chars. Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# JWT issuer claim — must match on validation. Default: kingswalk-scada
JWT_ISSUER=kingswalk-scada

# Access token lifetime in seconds (default: 900 = 15 minutes).
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in seconds (default: 604800 = 7 days).
REFRESH_TOKEN_TTL_SECONDS=604800

# CSRF cookie signing secret — min 64 hex chars. Generate same way.
CSRF_SECRET=

# MFA secret encryption key — base64-encoded 32 random bytes. Generate:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MFA_ENCRYPTION_KEY=

# ─── Edge gateway ─────────────────────────────────────────────────────────────
# Edge gateway ingest API key — must match EDGE_TOKEN in edge/edge.env.example
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
EDGE_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Resend API key. Leave empty to skip all outbound email (dev mode).
# Get one at https://resend.com
RESEND_API_KEY=

# Public URL of the frontend app — used in email links (invite, password reset).
APP_URL=http://localhost:5173

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Environment name shown in logs and health endpoint.
# Values: development | staging | production
ENVIRONMENT=development

# Structlog log level. Values: debug | info | warning | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins (JSON array format).
CORS_ORIGINS=["http://localhost:5173"]

# Application version — override only for staged rollouts.
VERSION=0.1.0
