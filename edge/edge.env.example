# /etc/kingswalk-edge/edge.env — copy to /etc/kingswalk-edge/edge.env on the gateway device

# Cloud API endpoint (Railway production URL)
CLOUD_URL=https://api.kingswalk-scada.railway.app

# Edge service token — generate via the admin API or Doppler
EDGE_TOKEN=

# SQLite buffer path — must be on the 64GB SSD
EDGE_BUFFER_PATH=/var/lib/kingswalk-edge/edge_buffer.db

# Health endpoint port (accessible on the SCADA management VLAN)
HEALTH_PORT=9090

# Main board Modbus TCP hosts — one per VLAN
# TODO: VERIFY_REGISTER — confirm IPs with Profection site survey
MB_1_1_HOST=10.10.11.10
MB_2_1_HOST=10.10.21.10
MB_2_2_HOST=10.10.22.10
MB_2_3_HOST=10.10.23.10
MB_3_1_HOST=10.10.31.10
MB_4_1_HOST=10.10.41.10
MB_5_1_HOST=10.10.51.10
MB_5_2_HOST=10.10.52.10
MB_5_3_HOST=10.10.53.10
